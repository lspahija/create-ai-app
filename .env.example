# Required for AI features (Claude CLI or SDK)
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: enable password auth for the web UI
AUTH_PASSWORD=

# Optional: separate JWT signing key (defaults to hash of AUTH_PASSWORD if not set)
# Recommended for production — use a high-entropy random string
JWT_SECRET=

# Optional: allow cross-origin requests (comma-separated origins)
# Only needed if your frontend is served from a different domain
CORS_ORIGINS=
